{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "codebus",
  "version": "0.1.0",
  "identifier": "dev.codebus.app",
  "build": {
    "frontendDist": "../../web/.output/public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm --prefix ../../web run dev",
    "beforeBuildCommand": "npm --prefix ../../web run generate"
  },
  "app": {
    "windows": [
      {
        "title": "CodeBus",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "../../sidecar/dist/codebus-sidecar"
    ]
  }
}
